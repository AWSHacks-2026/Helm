# Copy to helm/.env — prefer: aws login / SSO (no static keys required)
# AWS_ACCESS_KEY_ID=   # only if using static keys via aws configure
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Arbitration: mock | legacy invoke_model | AgentCore Runtime (merge only)
HELM_MOCK_BEDROCK=0
HELM_ARBITRATOR_ARN=
# Use inference profile IDs (us.*), not raw anthropic.* foundation model IDs
# Helm coordination (dedup, resolve, guardrail LLM) — Haiku 4.5
HELM_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
HELM_BEDROCK_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Simulated coding agents (live matrix benchmark)
HELM_AGENT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
LIVE_BASELINE_MAX_ROUNDS=3
LIVE_AGENT_MAX_TOKENS=4096
# Lower cap for Helm-reassigned agents (focused patches, not full modules)
LIVE_AGENT_REASSIGN_MAX_TOKENS=1024
# Fleet merge: one Sonnet call per conflicted file (parallel when >1 file)
MERGE_FLEET_PARALLEL=1
MERGE_FLEET_MAX_TOKENS=4096
# haiku_chain (default, cheap) | sonnet (full Sonnet arbitration per file)
MERGE_FLEET_STRATEGY=haiku_chain
MERGE_FLEET_HAIKU_ROUNDS=1
# Set 1 to re-merge failed files with Sonnet (higher quality, ~3× cost)
MERGE_FLEET_ESCALATE_SONNET=0
# Guardrail LLM tier: tiered (default) | haiku | sonnet
GUARDRAIL_STRATEGY=tiered
GUARDRAIL_SONNET_MIN_AGENTS=3
GUARDRAIL_SONNET_MIN_FILES=2
GUARDRAIL_SONNET_KB_EVENTS=8
GUARDRAIL_SONNET_RULES=intent_contradiction
GUARDRAIL_HAIKU_MAX_TOKENS=1024
GUARDRAIL_SONNET_MAX_TOKENS=1500
GUARDRAIL_ESCALATE_SONNET=0
# Dynamic inference across guardrail, intent, dedup, merge (pairwise)
HELM_INFERENCE_STRATEGY=tiered
HELM_SONNET_COMPLEXITY_THRESHOLD=45

# Contention gate — skip Bedrock coordination when agents do not collide
HELM_GATE_ENABLED=1
HELM_GATE_FORCE=0
HELM_GATE_MIN_AGENTS=2
HELM_GATE_INTENT_OVERLAP=0.35
HELM_GATE_FAIL_MODE=open
HELM_GATE_TRIAGE=0
HELM_GATE_LOG_SKIPS=1

# ShopFix git benchmark (repo-root shopfix/, sibling of helm/)
SHOPFIX_FIXTURE_DIR=../shopfix
SHOPFIX_HELM_API=http://127.0.0.1:8000
SHOPFIX_AGENT_COUNTS=2,4,6,8
SHOPFIX_USE_PATCHES=0
SHOPFIX_KEEP_SANDBOX=0

LIVE_BENCHMARK_SEED_MODE=scenario
LIVE_BENCHMARK_DISABLED=0

# Multi-machine team demo (shared API + session)
# HELM_TEAM_SESSION=mergeai-hackathon-demo
# HELM_REPO_SLUG=AWSHacks-2026/MergeAI
# HELM_BRANCH=main
# Set on each laptop MCP client (not on server):
# HELM_API_BASE=https://YOUR-SHARED-HOST
# HELM_AGENT_ID=agent_a

# GitHub Issues delegation (server)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=AWSHacks-2026/MergeAI
# GITHUB_WEBHOOK_SECRET=change-me
# GITHUB_LABEL_FILE_MAP={"auth":"src/auth/","catalog":"src/catalog/"}
# GITHUB_READY_LABEL=helm-ready
# GITHUB_MOCK=1

# AgentCore Memory + Policy
HELM_USE_LOCAL_MEMORY=true
HELM_USE_LOCAL_POLICY=true
HELM_SESSION_PATH=.helm/session.json

# Optional: AgentCore cloud resources
# AGENTCORE_MEMORY_ID=
# AGENTCORE_POLICY_ENGINE_ID=
# AGENTCORE_GATEWAY_ARN=

# Legacy (deprecated — use AgentCore Memory instead)
# HELM_USE_LOCAL_KB=true
# HELM_S3_BUCKET=
# BEDROCK_KB_ID=
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT
