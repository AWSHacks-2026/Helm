# Root: track only helm/, shopfix/, streamcast/, README.md (+ this file)
/*
!.gitignore
!/README.md
!/helm/
!/helm/**
!/shopfix/
!/shopfix/**
!/streamcast/
!/streamcast/**

# Root paths (including dotdirs not matched by /*)
/.github/
/.worktrees/
/agent_docs/
/docs/
/.venv/
/.overlord/
/.superpowers/
/.helm/
.env
AWSHacks2026_Rubric.pdf
*.png
helm_architecture.html

# Artifacts inside allowed trees
.helm/
.overlord/
.superpowers/
helm/STACK_PRIVATE.md
*.env.local
helm/data/sessions/
backend/.venv/
helm/.venv/
__pycache__/
*.py[cod]
*.pyc
node_modules/
helm/frontend/dist/
helm/experiments/results/
shopfix/.git/
shopfix/backend/.venv/
shopfix/frontend/node_modules/
shopfix/frontend/dist/
