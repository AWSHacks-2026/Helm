# Copy to overlord/.env — prefer: aws login / SSO (no static keys required)
AWS_DEFAULT_REGION=us-east-1

# Arbitration: mock | legacy invoke_model | AgentCore Runtime
OVERLORD_MOCK_BEDROCK=0
OVERLORD_ARBITRATOR_ARN=
# Default: Claude Sonnet 4.6 (enable in Bedrock console → Model access)
OVERLORD_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# Knowledge Base + session (unchanged)
OVERLORD_USE_LOCAL_KB=true
OVERLORD_SESSION_PATH=.overlord/session.json

# Optional: real Bedrock Knowledge Base + Guardrails
# OVERLORD_S3_BUCKET=your-overlord-logs-bucket
# BEDROCK_KB_ID=
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT
