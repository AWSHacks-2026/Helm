# Copy to overlord/.env and fill in after AWS setup (PRD §9)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Alias supported by boto3 tooling:
# AWS_DEFAULT_REGION=us-east-1
# Optional: skip real Bedrock in manual smoke tests
OVERLORD_MOCK_BEDROCK=0

# AgentCore Memory + Policy (local demo defaults)
OVERLORD_USE_LOCAL_MEMORY=true
OVERLORD_USE_LOCAL_POLICY=true
OVERLORD_SESSION_PATH=.overlord/session.json

# Optional: AgentCore cloud resources
# AGENTCORE_MEMORY_ID=
# AGENTCORE_POLICY_ENGINE_ID=
# AGENTCORE_GATEWAY_ARN=

# Legacy (deprecated — use AgentCore Memory instead)
# OVERLORD_USE_LOCAL_KB=true
# OVERLORD_S3_BUCKET=
# BEDROCK_KB_ID=
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT
