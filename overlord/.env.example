# Copy to overlord/.env — prefer: aws login / SSO (no static keys required)
# AWS_ACCESS_KEY_ID=   # only if using static keys via aws configure
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Arbitration: mock | legacy invoke_model | AgentCore Runtime (merge only)
OVERLORD_MOCK_BEDROCK=0
OVERLORD_ARBITRATOR_ARN=
# Use inference profile IDs (us.*), not raw anthropic.* foundation model IDs
OVERLORD_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# Alias supported by arbitration.runner
OVERLORD_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# Haiku agents for live merge benchmark (Haiku 4.5; 3.5 is legacy on many accounts)
OVERLORD_AGENT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
LIVE_BASELINE_MAX_ROUNDS=3
LIVE_AGENT_MAX_TOKENS=800
LIVE_BENCHMARK_SEED_MODE=scenario
LIVE_BENCHMARK_DISABLED=0

# Multi-machine team demo (shared API + session)
# OVERLORD_TEAM_SESSION=mergeai-hackathon-demo
# OVERLORD_REPO_SLUG=AWSHacks-2026/MergeAI
# OVERLORD_BRANCH=main
# Set on each laptop MCP client (not on server):
# OVERLORD_API_BASE=https://YOUR-SHARED-HOST

# AgentCore Memory + Policy
OVERLORD_USE_LOCAL_MEMORY=true
OVERLORD_USE_LOCAL_POLICY=true
OVERLORD_SESSION_PATH=.overlord/session.json

# Optional: AgentCore cloud resources
# AGENTCORE_MEMORY_ID=
# AGENTCORE_POLICY_ENGINE_ID=
# AGENTCORE_GATEWAY_ARN=

# Legacy (deprecated — use AgentCore Memory instead)
# OVERLORD_USE_LOCAL_KB=true
# OVERLORD_S3_BUCKET=
# BEDROCK_KB_ID=
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT
